# Copy to .env — never commit .env.
STRIPE_SECRET_KEY=sk_live_REPLACE_ME

# Safe to expose to browsers / mobile app (same value you may pass via --dart-define).
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# Stripe Dashboard → Developers → Webhooks → endpoint → Signing secret (starts with whsec_).
# Local: stripe listen --forward-to localhost:4242/webhook
STRIPE_WEBHOOK_SECRET=

# Public HTTPS origin of this server (no trailing slash). Checkout redirects to:
#   {PUBLIC_BASE_URL}/success?session_id={CHECKOUT_SESSION_ID}
#   {PUBLIC_BASE_URL}/canceled
PUBLIC_BASE_URL=https://your-api.example.com

# Optional overrides if you do not use PUBLIC_BASE_URL:
# CHECKOUT_SUCCESS_URL=https://your-api.example.com/success?session_id={CHECKOUT_SESSION_ID}
# CHECKOUT_CANCEL_URL=https://your-api.example.com/canceled

# CHECKOUT_AMOUNT_MINOR=1000
# CHECKOUT_CURRENCY=eur

PORT=4242
